---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchArticles, fetchHomePage, getStrapiMedia } from '../lib/strapi';
import { formatPublishDate, getFeaturedArticles } from '../lib/content';

const [homePage, allArticles] = await Promise.all([fetchHomePage(), fetchArticles()]);
const featuredArticles = getFeaturedArticles(allArticles, 3);

const heroTitle = homePage?.hero?.title ?? 'Build static websites with confidence';
const heroDescription =
  homePage?.hero?.description ??
  'Astro + Strapi integration keeps content dynamic in CMS while delivering static pages in production.';
---

<BaseLayout title="Home">
  <main class="max-w-6xl mx-auto px-6 py-12">
    <section class="text-center py-12">
      <h1 class="text-5xl font-black mb-4">{heroTitle}</h1>
      <p class="text-lg text-slate-600 dark:text-slate-300 max-w-3xl mx-auto">{heroDescription}</p>
    </section>

    <section class="mt-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-3xl font-bold">Featured Articles</h2>
        <a class="text-primary font-semibold" href="/blog">View all</a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {featuredArticles.map((article) => (
          <article class="border rounded-xl p-4">
            {article.cover ? (
              <img
                src={getStrapiMedia(article.cover) ?? ''}
                alt={article.cover.alternativeText ?? article.title}
                class="w-full aspect-video object-cover rounded-lg mb-4"
                loading="lazy"
              />
            ) : (
              <div class="w-full aspect-video rounded-lg bg-slate-100 dark:bg-slate-800 mb-4" />
            )}
            <p class="text-xs text-primary font-semibold uppercase">{article.category?.name ?? 'Uncategorized'}</p>
            <h3 class="text-xl font-bold mt-2"><a href={`/blog/${article.slug}`}>{article.title}</a></h3>
            <p class="text-slate-500 mt-2 text-sm">{formatPublishDate(article.publishedAt)}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
