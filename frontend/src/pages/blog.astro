---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchArticles, fetchCategories, getStrapiMedia } from '../lib/strapi';
import { formatPublishDate } from '../lib/content';

let articles = [];
let categories = [];
let pageError = '';

try {
  [articles, categories] = await Promise.all([fetchArticles(), fetchCategories()]);
} catch (error) {
  pageError = error instanceof Error ? error.message : 'Unable to load blog content.';
}
---

<BaseLayout title="Blog">
  <main class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-black mb-8">Blog</h1>

    {pageError && (
      <p class="rounded-lg border border-red-300 bg-red-50 p-4 text-red-700 mb-8">{pageError}</p>
    )}

    <div class="flex gap-3 flex-wrap mb-8" id="category-filter">
      <button class="filter-btn active px-4 py-2 rounded-full border" data-category="all">All</button>
      {categories.map((category) => (
        <button class="filter-btn px-4 py-2 rounded-full border" data-category={category.slug}>
          {category.name}
        </button>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="article-grid">
      {articles.map((article) => (
        <article class="rounded-xl border p-4" data-article-category={article.category?.slug ?? ''}>
          {article.cover ? (
            <img
              src={getStrapiMedia(article.cover) ?? ''}
              alt={article.cover.alternativeText ?? article.title}
              class="mb-4 aspect-video w-full object-cover rounded-lg"
              loading="lazy"
            />
          ) : (
            <div class="mb-4 aspect-video w-full rounded-lg bg-slate-100 dark:bg-slate-800 grid place-items-center text-slate-500">
              No image
            </div>
          )}
          <p class="text-xs uppercase tracking-wide text-primary font-bold">{article.category?.name ?? 'Uncategorized'}</p>
          <h2 class="text-xl font-bold mt-2"><a href={`/blog/${article.slug}`}>{article.title}</a></h2>
          <p class="text-slate-600 dark:text-slate-300 mt-2">{article.description}</p>
          <p class="text-sm mt-3 text-slate-500">
            {formatPublishDate(article.publishedAt)} · {article.author?.name ?? 'Unknown author'}
          </p>
        </article>
      ))}
    </div>

    {articles.length === 0 && !pageError && <p>No articles available yet.</p>}
  </main>

  <script>
    const buttons = Array.from(document.querySelectorAll('.filter-btn'));
    const cards = Array.from(document.querySelectorAll('[data-article-category]'));

    const setActive = (active) => {
      buttons.forEach((button) => {
        const isActive = button === active;
        button.classList.toggle('active', isActive);
        button.classList.toggle('bg-primary', isActive);
        button.classList.toggle('font-bold', isActive);
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const category = button.dataset.category ?? 'all';
        setActive(button);

        cards.forEach((card) => {
          const cardCategory = card.getAttribute('data-article-category');
          const visible = category === 'all' || cardCategory === category;
          card.classList.toggle('hidden', !visible);
        });
      });
    });
  </script>
</BaseLayout>
